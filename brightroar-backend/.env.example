# App
APP_NAME=Brightroar Asset Manager
APP_VERSION=1.0.0
DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# PostgreSQL
POSTGRES_USER=brightroar
POSTGRES_PASSWORD=brightroar_secret
POSTGRES_DB=brightroar_db
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://brightroar:brightroar_secret@db:5432/brightroar_db

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret
REDIS_URL=redis://:redis_secret@redis:6379/0

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
